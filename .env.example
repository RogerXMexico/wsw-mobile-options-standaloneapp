# Wall Street Wildlife Mobile - Environment Variables
# Copy this file to .env and fill in your values

# Supabase
EXPO_PUBLIC_SUPABASE_URL=your-supabase-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Tradier API (for real-time market data)
EXPO_PUBLIC_TRADIER_API_KEY=your-tradier-api-key
EXPO_PUBLIC_TRADIER_ACCOUNT_ID=your-tradier-account-id

# Google Gemini AI (for strategy recommendations)
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# RevenueCat (for subscriptions)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=your-revenuecat-ios-key
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=your-revenuecat-android-key

# Sentry (for crash reporting)
SENTRY_DSN=your-sentry-dsn
